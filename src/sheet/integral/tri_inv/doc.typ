\[
    \int x \arcsin \dfrac{x}{a} \md x= (\dfrac{x^2}{2}-\dfrac{a^2}{4})\arcsin \dfrac{x}{a} + \dfrac{x}{4} \sqrt{x^2-x^2}+C~(a>0)
\]

\[
    \int x^2 \arcsin \dfrac{x}{a} \md x = \dfrac{x^3}{3}\arcsin \dfrac{x}{a}+\dfrac{1}{9}(x^2+2 a^2)\sqrt{a^2-x^2}+C~(a>0)
\]

\[
    \int x \arccos \dfrac{x}{a} \md x= (\dfrac{x^2}{2}-\dfrac{a^2}{4})\arccos \dfrac{x}{a} - \dfrac{x}{4} \sqrt{a^2-x^2}+C~(a>0)
\]

\[
    \int x^2 \arccos \dfrac{x}{a}\md x= \dfrac{x^3}{3}\arccos \dfrac{x}{a} - \dfrac{1}{9}(x^2+2a^2)\sqrt{a^2-x^2}+C~(a>0)
\]

\[
    \int x\arctan \dfrac{x}{a} \md x = \dfrac{1}{2}(a^2+x^2)\arctan \dfrac{x}{a} -\dfrac{a}{2}x+C~(a>0)
\]

\[
    \int x^2 \arctan \dfrac{x}{a} \md x= \dfrac{x^3}{3} \arctan \dfrac{x}{a} - \dfrac{a}{6}x^2 + \dfrac{a^3}{6} \ln (a^2+x^2)+C~(a>0)
\]
