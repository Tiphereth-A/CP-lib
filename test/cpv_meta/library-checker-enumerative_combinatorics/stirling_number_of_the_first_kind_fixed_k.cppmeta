// competitive-verifier: PROBLEM https://judge.yosupo.jp/problem/stirling_number_of_the_first_kind_fixed_k
#include "../../../src/comb/seq/stirling1_col/lib.hpp"
#include "../../../src/io/fastin/lib.hpp"
#include "../../../src/io/fastout/lib.hpp"

using namespace tifa_libs;
CEXP u32 MOD = 998244353;

// ---<GENTC>--- begin
// ---<GENTC>--- append poly_nttmod
// ---<GENTC>--- end

int main() {
  u32 n, k;
  tifa_libs::fin_uint >> n >> k;
  auto ans = tifa_libs::gen_stirling1_col<poly>(n, k);
  flt_ (u32, i, k, n + 1) tifa_libs::fout << ans[i] << " \n"[i == n];
  return 0;
}
