---
Checks:
  - -*
  - clang-analyzer-*
  - modernize-*
  - -modernize-avoid-c-style-cast
  - -modernize-use-trailing-return-type
  - -modernize-use-nodiscard
  - performance-*
  - misc-*
  - -misc-include-cleaner
  - -misc-non-private-member-variables-in-classes
WarningsAsErrors: ''
HeaderFileExtensions:
  - ''
  - h
  - hh
  - hpp
  - hxx
ImplementationFileExtensions:
  - c
  - cc
  - cpp
  - cxx
HeaderFilterRegex: '.*'
FormatStyle: file
SystemHeaders: false
ExtraArgs:
  - -std=gnu++20
...
